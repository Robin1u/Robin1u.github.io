---
import { getCollection, render } from 'astro:content';  // ← 导入 render
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('thoughts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);  // ← render(post)，不是 post.render()
---
<BaseLayout title={post.data.title} activePage="thoughts">
  <article style="max-width:680px; margin: 64px auto; padding: 0 64px 64px;">
    <div style="display:flex; gap:12px; align-items:center; margin-bottom:24px; flex-wrap:wrap;">
      <span class="post-date">{post.data.date.toLocaleDateString('zh-CN')}</span>
      <span class="post-category">{post.data.category}</span>
      <span class="post-read-time">{post.data.readTime} min read</span>
    </div>
    <h1 style="font-size:clamp(28px,3vw,42px); font-weight:800; color:var(--color-white); letter-spacing:-0.03em; margin-bottom:32px; line-height:1.15;">
      {post.data.title}
    </h1>
    <div class="prose">
      <Content />
    </div>
    <div style="margin-top:48px; padding-top:32px; border-top:1px solid var(--color-border);">
      <a href="/thoughts" style="display:inline-flex; align-items:center; gap:8px; color:var(--color-text-muted); font-size:13px;">
        ← 返回全部文章
      </a>
    </div>
  </article>
</BaseLayout>