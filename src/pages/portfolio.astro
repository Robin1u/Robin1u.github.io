---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { projectCategoryLabels } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const portfolioPage = pagesEntry?.data?.portfolio ?? {
  sectionNumber: '02',
  navLabel: '作品集',
  navLabelEn: 'Portfolio',
  intro: '这里收录我正在做和已经完成的项目。从最初的想法，到设计、搭建与迭代，它们记录了我如何把抽象的概念变成具体的结果。',
  introEn: 'This is where I keep the projects I am building and the ones I have already finished. From the first idea to design, building, and iteration, they record how I turn abstract concepts into concrete outcomes.',
};

const categories = [
  { key: 'all', label: projectCategoryLabels.all },
  { key: 'web', label: projectCategoryLabels.web },
  { key: 'design', label: projectCategoryLabels.design },
  { key: 'tool', label: projectCategoryLabels.tool },
  { key: 'mobile', label: projectCategoryLabels.mobile },
];
---
<BaseLayout
  title={portfolioPage.navLabel}
  titleEn={portfolioPage.navLabelEn ?? portfolioPage.navLabel}
  description="Robin Lu 的项目与作品集"
  descriptionEn="Projects and selected work by Robin Lu"
  activePage="portfolio"
>
  <section class="page-hero">
    <div class="section-header" style="margin-bottom:0;">
      <span class="section-number">{portfolioPage.sectionNumber}</span>
      <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);">
        <I18nText zh={portfolioPage.navLabel} en={portfolioPage.navLabelEn ?? portfolioPage.navLabel} />
      </h1>
      <div class="section-line"></div>
    </div>
    <p style="margin-top:16px;">
      <I18nText
        zh={portfolioPage.intro}
        en={portfolioPage.introEn ?? portfolioPage.intro}
      />
    </p>
  </section>

  <div class="filter-bar">
    {categories.map((category, index) => (
      <button class:list={['filter-btn', { active: index === 0 }]} data-filter={category.key}>
        <I18nText zh={category.label.zh} en={category.label.en} />
      </button>
    ))}
  </div>

  {projects.length > 0 ? (
    <div class="portfolio-grid">
      {projects.map((project, index) => {
        const titleEn = project.data.titleEn ?? project.data.title;
        const descriptionEn = project.data.descriptionEn ?? project.data.description;
        const categoryCopy = project.data.category ? projectCategoryLabels[project.data.category] : undefined;

        return (
          <a
            href={`/portfolio/${project.id}`}
            class:list={['portfolio-card', { featured: index === 0 && projects.length > 1 && project.data.featured }]}
            data-category={project.data.category ?? 'uncategorized'}
          >
            <div class="portfolio-card-image">
              {project.data.image
                ? (
                  <img
                    src={project.data.image}
                    alt={project.data.title}
                    data-i18n-alt-zh={project.data.title}
                    data-i18n-alt-en={titleEn}
                    loading="lazy"
                  />
                )
                : (
                  <I18nText
                    as="div"
                    class="img-placeholder"
                    zh={project.data.title.slice(0, 2)}
                    en={titleEn.slice(0, 2)}
                  />
                )}
            </div>
            <div class="portfolio-card-body">
              <div class="portfolio-card-tags">
                {categoryCopy && <span class="tag accent"><I18nText zh={categoryCopy.zh} en={categoryCopy.en} /></span>}
                {(project.data.tags ?? []).slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <h3 class="portfolio-card-title"><I18nText zh={project.data.title} en={titleEn} /></h3>
              {project.data.description && descriptionEn && <p class="portfolio-card-desc"><I18nText zh={project.data.description} en={descriptionEn} /></p>}
              <span class="portfolio-card-link">
                <I18nText zh="查看详情" en="View Details" />
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  ) : (
    <div class="quote-block" style="margin:48px 64px;">
      <p class="quote-text"><I18nText zh="当前还没有项目内容。" en="No projects yet." /></p>
    </div>
  )}

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/"><I18nText zh="首页" en="Home" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
      <a href="/channel"><I18nText zh="频道" en="Channels" /></a>
    </nav>
  </footer>
</BaseLayout>

<style>
  .portfolio-card.featured {
    grid-column: 1 / -1;
  }

  .portfolio-card.featured .portfolio-card-image {
    aspect-ratio: 21 / 7;
  }
</style>
