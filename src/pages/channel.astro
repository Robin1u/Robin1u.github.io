---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const platformMeta = {
  bilibili: {
    labelZh: 'Bilibili',
    labelEn: 'Bilibili',
    color: '#00a1d6',
  },
  xiaohongshu: {
    labelZh: '小红书',
    labelEn: 'Xiaohongshu',
    color: '#ff5555',
  },
  github: {
    labelZh: 'GitHub',
    labelEn: 'GitHub',
    color: '#e8e8e8',
  },
};

const [channelEntry] = await getCollection('siteChannel').catch(() => []);
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const channelSettings = channelEntry?.data ?? {
  channels: [],
};
const channelPage = pagesEntry?.data?.channel ?? {
  sectionNumber: '05',
  pageTitle: '频道',
  pageTitleEn: 'Channels',
  intro: '这里适合作为平台入口页，集中放置账号链接、简短介绍和更新方向。',
  introEn: 'This page works best as a hub for profile links, short intros, and the direction of your ongoing work.',
};
const channels = channelSettings.channels ?? [];
---
<BaseLayout
  title={channelPage.pageTitle}
  titleEn={channelPage.pageTitleEn ?? channelPage.pageTitle}
  description="Robin Lu 的频道与平台数据"
  descriptionEn="Channel and platform links for Robin Lu"
  activePage="channel"
>
  <section class="channel-hero">
    <div class="section-header" style="margin-bottom:0;">
      <span class="section-number">{channelPage.sectionNumber}</span>
      <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);">
        <I18nText zh={channelPage.pageTitle} en={channelPage.pageTitleEn ?? channelPage.pageTitle} />
      </h1>
      <div class="section-line"></div>
    </div>
    <p style="margin-top:16px; max-width:620px; color:var(--color-text-muted);">
      <I18nText
        zh={channelPage.intro}
        en={channelPage.introEn ?? channelPage.intro}
      />
    </p>
  </section>

  {channels.length > 0 ? (
    <div class="channel-list">
      {channels.map((channel) => {
        const meta = platformMeta[channel.platform];
        const titleZh = channel.title || meta.labelZh;
        const titleEn = channel.titleEn || channel.title || meta.labelEn;
        const descriptionZh = channel.description || '';
        const descriptionEn = channel.descriptionEn || channel.description || '';

        return (
          <article class="channel-card" data-platform={channel.platform}>
            <div class="channel-card-header">
              <div class="channel-icon" style={`background-color:${meta.color}22; color:${meta.color};`}>
                <span style="font-weight:700;">{meta.labelZh.slice(0, 1)}</span>
              </div>
              <div class="channel-info">
                <div class="channel-platform"><I18nText zh={meta.labelZh} en={meta.labelEn} /></div>
                <h2 class="channel-name" style={`color:${meta.color};`}><I18nText zh={titleZh} en={titleEn} /></h2>
                {channel.handle && <div class="channel-subs">{channel.handle}</div>}
              </div>
              {channel.url && (
                <a href={channel.url} class="channel-follow-btn" target="_blank" rel="noopener" style={`background-color:${meta.color}; color:#0a0a0a;`}>
                  <I18nText zh="打开链接" en="Open Link" />
                </a>
              )}
            </div>

            {(descriptionZh || descriptionEn) && (
              <p class="channel-desc">
                <I18nText zh={descriptionZh || ' '} en={descriptionEn || descriptionZh || ' '} />
              </p>
            )}
          </article>
        );
      })}
    </div>
  ) : (
    <div class="quote-block" style="margin:48px 64px;">
      <p class="quote-text"><I18nText zh="当前还没有配置频道链接。" en="No channel links configured yet." /></p>
    </div>
  )}

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/"><I18nText zh="首页" en="Home" /></a>
      <a href="/portfolio"><I18nText zh="作品集" en="Portfolio" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
    </nav>
  </footer>
</BaseLayout>
