---
import stats from '../../data/stats.json';
import I18nText from '../components/I18nText.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const channels = [
  {
    platform: 'Bilibili',
    name: { zh: '内容频道', en: 'Content Channel' },
    stats: [
      { value: `${stats.bilibili.followers}`, label: { zh: '关注', en: 'Followers' } },
      { value: `${stats.bilibili.videos}`, label: { zh: '视频', en: 'Videos' } },
      { value: `${stats.bilibili.views}`, label: { zh: '播放', en: 'Views' } },
    ],
    updated: stats.bilibili.updated,
    key: 'bilibili',
  },
  {
    platform: 'GitHub',
    name: { zh: '代码频道', en: 'Code Channel' },
    stats: [
      { value: `${stats.github.followers}`, label: { zh: '关注', en: 'Followers' } },
      { value: `${stats.github.repos}`, label: { zh: '仓库', en: 'Repos' } },
      { value: `${stats.github.stars}`, label: { zh: 'Stars', en: 'Stars' } },
    ],
    updated: stats.github.updated,
    key: 'github',
  },
];
---
<BaseLayout
  title="频道"
  titleEn="Channels"
  description="Robin Lu 的频道与平台数据"
  descriptionEn="Channel and platform stats for Robin Lu"
  activePage="channel"
>
  <section class="channel-hero">
    <div class="section-header" style="margin-bottom:0;">
      <span class="section-number">03</span>
      <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);"><I18nText zh="频道" en="Channels" /></h1>
      <div class="section-line"></div>
    </div>
    <p style="margin-top:16px; max-width:560px; color:var(--color-text-muted);">
      <I18nText
        zh="这一页保留频道路由与框架结构，当前展示仓库里已有的频道统计数据。"
        en="This page keeps the channel route and layout in place while showing the stats already stored in the repository."
      />
    </p>
  </section>

  <div class="channel-list">
    {channels.map((channel) => (
      <article class="channel-card" data-ch={channel.key}>
        <div class="channel-card-header">
          <div class:list={['channel-icon', channel.key]} aria-hidden="true">
            <span style="font-weight:700;">{channel.platform.slice(0, 1)}</span>
          </div>
          <div class="channel-info">
            <div class="channel-platform">{channel.platform}</div>
            <h2 class="channel-name"><I18nText zh={channel.name.zh} en={channel.name.en} /></h2>
            <div class="channel-subs">
              <I18nText zh={`最近更新：${channel.updated}`} en={`Last updated: ${channel.updated}`} />
            </div>
          </div>
        </div>

        <div class="channel-stats">
          {channel.stats.map((stat) => (
            <div class="ch-stat">
              <span class="ch-stat-num">{stat.value}</span>
              <span class="ch-stat-label"><I18nText zh={stat.label.zh} en={stat.label.en} /></span>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/"><I18nText zh="首页" en="Home" /></a>
      <a href="/portfolio"><I18nText zh="作品集" en="Portfolio" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
    </nav>
  </footer>
</BaseLayout>

<style>
  .channel-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 0;
    flex-wrap: wrap;
  }

  .ch-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ch-stat-num {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-white);
    font-family: var(--font-mono);
    letter-spacing: -0.02em;
  }

  .ch-stat-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }
  .channel-card[data-ch='bilibili'] .channel-name {
    color: #00a1d6;
  }
  .channel-card[data-ch='github'] .channel-name {
    color: #e8e8e8;
  }
</style>
