---
import { getEntry } from 'astro:content';
import stats from '../../data/stats.json';
import I18nText from '../components/I18nText.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const platformMeta = {
  bilibili: {
    labelZh: 'Bilibili',
    labelEn: 'Bilibili',
    color: '#00a1d6',
  },
  xiaohongshu: {
    labelZh: '小红书',
    labelEn: 'Xiaohongshu',
    color: '#ff5555',
  },
  github: {
    labelZh: 'GitHub',
    labelEn: 'GitHub',
    color: '#e8e8e8',
  },
};

const statsMap = {
  bilibili: stats.bilibili,
  github: stats.github,
};

const siteEntry = await getEntry('site', 'home').catch(() => null);
const channels = siteEntry?.data?.channels ?? [];
---
<BaseLayout
  title="频道"
  titleEn="Channels"
  description="Robin Lu 的频道与平台数据"
  descriptionEn="Channel and platform links for Robin Lu"
  activePage="channel"
>
  <section class="channel-hero">
    <div class="section-header" style="margin-bottom:0;">
      <span class="section-number">03</span>
      <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);"><I18nText zh="频道" en="Channels" /></h1>
      <div class="section-line"></div>
    </div>
    <p style="margin-top:16px; max-width:620px; color:var(--color-text-muted);">
      <I18nText
        zh="这里更适合做平台入口页：放账号链接、简短介绍和最新更新方向。先把 B 站和小红书集中在这里，后续如果 ADHDer 内容沉淀成体系，再拆出独立专题页会更清晰。"
        en="This page works best as a platform hub for profile links, short introductions, and the latest direction of your work. Keep Bilibili and Xiaohongshu here first, then create a dedicated topic page later if your ADHDer content grows into a bigger knowledge base."
      />
    </p>
  </section>

  {channels.length > 0 ? (
    <div class="channel-list">
      {channels.map((channel) => {
        const meta = platformMeta[channel.platform];
        const platformStats = statsMap[channel.platform];
        const titleZh = channel.title || meta.labelZh;
        const titleEn = channel.titleEn || channel.title || meta.labelEn;
        const descriptionZh = channel.description || '';
        const descriptionEn = channel.descriptionEn || channel.description || '';

        return (
          <article class="channel-card" data-platform={channel.platform}>
            <div class="channel-card-header">
              <div class="channel-icon" style={`background-color:${meta.color}22; color:${meta.color};`}>
                <span style="font-weight:700;">{meta.labelZh.slice(0, 1)}</span>
              </div>
              <div class="channel-info">
                <div class="channel-platform"><I18nText zh={meta.labelZh} en={meta.labelEn} /></div>
                <h2 class="channel-name" style={`color:${meta.color};`}><I18nText zh={titleZh} en={titleEn} /></h2>
                {channel.handle && <div class="channel-subs">{channel.handle}</div>}
              </div>
              {channel.url && (
                <a href={channel.url} class="channel-follow-btn" target="_blank" rel="noopener" style={`background-color:${meta.color}; color:#0a0a0a;`}>
                  <I18nText zh="打开链接" en="Open Link" />
                </a>
              )}
            </div>

            {(descriptionZh || descriptionEn) && (
              <p class="channel-desc">
                <I18nText zh={descriptionZh || ' '} en={descriptionEn || descriptionZh || ' '} />
              </p>
            )}

            {platformStats && (
              <div class="channel-stats">
                {'followers' in platformStats && (
                  <div class="ch-stat">
                    <span class="ch-stat-num">{platformStats.followers}</span>
                    <span class="ch-stat-label"><I18nText zh="关注" en="Followers" /></span>
                  </div>
                )}
                {'videos' in platformStats && (
                  <div class="ch-stat">
                    <span class="ch-stat-num">{platformStats.videos}</span>
                    <span class="ch-stat-label"><I18nText zh="视频" en="Videos" /></span>
                  </div>
                )}
                {'views' in platformStats && (
                  <div class="ch-stat">
                    <span class="ch-stat-num">{platformStats.views}</span>
                    <span class="ch-stat-label"><I18nText zh="播放" en="Views" /></span>
                  </div>
                )}
                {'repos' in platformStats && (
                  <div class="ch-stat">
                    <span class="ch-stat-num">{platformStats.repos}</span>
                    <span class="ch-stat-label"><I18nText zh="仓库" en="Repos" /></span>
                  </div>
                )}
                {'stars' in platformStats && (
                  <div class="ch-stat">
                    <span class="ch-stat-num">{platformStats.stars}</span>
                    <span class="ch-stat-label"><I18nText zh="Stars" en="Stars" /></span>
                  </div>
                )}
              </div>
            )}
          </article>
        );
      })}
    </div>
  ) : (
    <div class="quote-block" style="margin:48px 64px;">
      <p class="quote-text"><I18nText zh="当前还没有配置频道链接。" en="No channel links configured yet." /></p>
    </div>
  )}

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/"><I18nText zh="首页" en="Home" /></a>
      <a href="/portfolio"><I18nText zh="作品集" en="Portfolio" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
    </nav>
  </footer>

  <style>
    .channel-stats {
      display: flex;
      gap: 24px;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .ch-stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .ch-stat-num {
      font-size: 18px;
      font-weight: 800;
      color: var(--color-white);
      font-family: var(--font-mono);
      letter-spacing: -0.02em;
    }

    .ch-stat-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text-subtle);
    }
  </style>
</BaseLayout>
