---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';
const thoughts = (await getCollection('thoughts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categoryCount = new Set(thoughts.map((post) => post.data.category).filter(Boolean)).size;
const tagCount = new Set(thoughts.flatMap((post) => post.data.tags ?? [])).size;
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const thoughtsPage = pagesEntry?.data?.thoughts ?? {
  sectionNumber: '03',
  navLabel: '想法',
  navLabelEn: 'Thoughts',
  intro: '这里专门放文字内容、观点整理和方法记录。',
  introEn: 'This page is dedicated to writing, reflections, and methods.',
};
---
<BaseLayout
  title={thoughtsPage.navLabel}
  titleEn={thoughtsPage.navLabelEn ?? thoughtsPage.navLabel}
  description="Robin Lu 的想法与文章"
  descriptionEn="Thoughts and writing from Robin Lu"
  activePage="thoughts"
>
  <div class="thoughts-layout">
    <div class="thoughts-main">
      <div class="thoughts-header">
        <div class="section-header" style="margin-bottom:0;">
          <span class="section-number">{thoughtsPage.sectionNumber}</span>
          <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);">
            <I18nText zh={thoughtsPage.navLabel} en={thoughtsPage.navLabelEn ?? thoughtsPage.navLabel} />
          </h1>
          <div class="section-line"></div>
        </div>
        <p style="color:var(--color-text-muted); margin-top:16px;">
          <I18nText
            zh={thoughtsPage.intro}
            en={thoughtsPage.introEn ?? thoughtsPage.intro}
          />
        </p>
      </div>

      <div class="tab-content active">
        {thoughts.length > 0 ? (
          <div class="post-list">
            {thoughts.map((post) => {
              const dateCopy = formatLocalizedDate(post.data.date);

              return (
                <a href={`/thoughts/${post.id}`} class="post-item" style="display:block">
                  <div class="post-item-meta">
                    <span class="post-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></span>
                    {post.data.category && <span class="post-category">{post.data.category}</span>}
                    {(post.data.tags ?? []).slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                  <h3>{post.data.title}</h3>
                  {post.data.description && <p>{post.data.description}</p>}
                  <div class="post-item-footer">
                    <span class="post-read-time"><I18nText zh={`${post.data.readTime} 分钟阅读`} en={`${post.data.readTime} min read`} /></span>
                    <span class="post-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="quote-block" style="margin:32px 64px;">
            <p class="quote-text"><I18nText zh="当前还没有文章内容。" en="No posts yet." /></p>
          </div>
        )}
      </div>
    </div>

    <aside class="thoughts-sidebar">
      <div class="sidebar-widget">
        <div class="widget-title"><I18nText zh="统计" en="Stats" /></div>
        <div class="topic-list">
          <div class="topic-item"><I18nText zh="文章" en="Posts" /><span class="topic-count">{thoughts.length}</span></div>
          {categoryCount > 0 && (
            <div class="topic-item"><I18nText zh="分类" en="Categories" /><span class="topic-count">{categoryCount}</span></div>
          )}
          {tagCount > 0 && (
            <div class="topic-item"><I18nText zh="标签" en="Tags" /><span class="topic-count">{tagCount}</span></div>
          )}
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
