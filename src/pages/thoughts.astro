---
import { readdirSync } from 'node:fs';
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

function hasMarkdownEntries(relativeDir) {
  try {
    return readdirSync(new URL(relativeDir, import.meta.url)).some((file) => file.endsWith('.md'));
  } catch {
    return false;
  }
}

async function safeGetCollection(name, shouldLoad = true) {
  if (!shouldLoad) {
    return [];
  }
  try {
    return await getCollection(name, ({ data }) => !data.draft);
  } catch {
    return [];
  }
}

const thoughts = (await safeGetCollection('thoughts', hasMarkdownEntries('../content/thoughts')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout
  title="想法"
  titleEn="Thoughts"
  description="Robin Lu 的想法与文章"
  descriptionEn="Thoughts and writing from Robin Lu"
  activePage="thoughts"
>
  <div class="thoughts-layout">
    <div class="thoughts-main">
      <div class="thoughts-header">
        <h1 style="font-size: clamp(28px,3vw,42px); font-weight:800; color:var(--color-white); letter-spacing:-0.03em;"><I18nText zh="想法" en="Thoughts" /></h1>
        <p style="color:var(--color-text-muted); margin-top:12px;">
          <I18nText
            zh="这里专门放文字内容、观点整理和方法记录。生活时间线与最近在做的事项，统一放到“生活”页面。"
            en="This page is dedicated to writing, reflections, and methods. Everyday updates and the ongoing timeline now live on the Life page."
          />
        </p>
      </div>

      <div class="tab-content active">
        {thoughts.length > 0 ? (
          <div class="post-list">
            {thoughts.map((post) => {
              const dateCopy = formatLocalizedDate(post.data.date);

              return (
                <a href={`/thoughts/${post.id}`} class="post-item" style="display:block">
                  <div class="post-item-meta">
                    <span class="post-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></span>
                    {post.data.category && <span class="post-category">{post.data.category}</span>}
                    {(post.data.tags ?? []).slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                  <h3>{post.data.title}</h3>
                  {post.data.description && <p>{post.data.description}</p>}
                  <div class="post-item-footer">
                    <span class="post-read-time"><I18nText zh={`${post.data.readTime} 分钟阅读`} en={`${post.data.readTime} min read`} /></span>
                    <span class="post-arrow">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="quote-block" style="margin:32px 64px;">
            <p class="quote-text"><I18nText zh="当前还没有文章内容。" en="No posts yet." /></p>
          </div>
        )}
      </div>
    </div>

    <aside class="thoughts-sidebar">
      <div class="sidebar-widget">
        <div class="widget-title"><I18nText zh="统计" en="Stats" /></div>
        <div class="topic-list">
          <div class="topic-item"><I18nText zh="文章 " en="Posts " /><span class="topic-count">{thoughts.length}</span></div>
          <a href="/life" class="topic-item" style="text-decoration:none;">
            <I18nText zh="查看生活页面" en="Open Life page" />
          </a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
