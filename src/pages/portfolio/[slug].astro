---
import { getCollection, render } from 'astro:content';  // ← 导入 render
import I18nText from '../../components/I18nText.astro';
import { projectCategoryLabels } from '../../lib/i18n';
import { renderMarkdownToHtml } from '../../lib/markdown';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);  // ← render(project)，不是 project.render()
const englishBodySource = project.data.bodyEn?.trim() ? project.data.bodyEn : project.body ?? '';
const hasEnglishBody = Boolean(englishBodySource.trim());
const titleEn = project.data.titleEn ?? project.data.title;
const descriptionEn = project.data.descriptionEn ?? project.data.description;
const categoryLabel = project.data.category ? projectCategoryLabels[project.data.category] : undefined;
const englishBodyHtml = hasEnglishBody ? await renderMarkdownToHtml(englishBodySource) : '';
const hasActionLinks = Boolean(project.data.liveUrl || project.data.githubUrl);
---
<BaseLayout
  title={project.data.title}
  titleEn={titleEn}
  description={project.data.description ?? '项目详情'}
  descriptionEn={descriptionEn ?? 'Project detail'}
  activePage="portfolio"
>
  <a href="/portfolio" class="floating-back-link">
    <span aria-hidden="true">←</span>
    <I18nText zh="返回作品集" en="Back to Portfolio" />
  </a>

  <article class="portfolio-detail-article">
    <div class="portfolio-card-image portfolio-card-image-desktop" style="border-radius:12px; margin-bottom:40px; aspect-ratio:16/9;">
      {project.data.image
        ? (
          <img
            src={project.data.image}
            alt={project.data.title}
            data-i18n-alt-zh={project.data.title}
            data-i18n-alt-en={titleEn}
            loading="eager"
            width="780"
            height="438"
            style="width:100%;height:100%;object-fit:cover;border-radius:12px;"
          />
        )
        : <I18nText as="div" class="img-placeholder" style="font-size:64px;" zh={project.data.title.slice(0, 2).toUpperCase()} en={titleEn.slice(0, 2).toUpperCase()} />
      }
    </div>

    <div class="portfolio-card-tags" style="margin-bottom:16px;">
      {categoryLabel && <span class="tag accent"><I18nText zh={categoryLabel.zh} en={categoryLabel.en} /></span>}
      {(project.data.tags ?? []).map(tag => <span class="tag">{tag}</span>)}
    </div>

    <h1 class="portfolio-detail-title">
      <I18nText zh={project.data.title} en={titleEn} />
    </h1>

    {project.data.description && descriptionEn && (
      <p class="portfolio-detail-desc">
        <I18nText zh={project.data.description} en={descriptionEn} />
      </p>
    )}

    {hasActionLinks && (
      <div class="portfolio-detail-actions">
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <I18nText zh="查看线上版本 ↗" en="Open Live Version ↗" />
          </a>
        )}
        {project.data.githubUrl && (
          <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            <I18nText zh="GitHub 源码 ↗" en="GitHub Source ↗" />
          </a>
        )}
      </div>
    )}

    <div class="prose">
      <div class="i18n-markdown" data-i18n-lang="zh">
        <Content />
      </div>
      {hasEnglishBody && <div class="i18n-markdown" data-i18n-lang="en" set:html={englishBodyHtml} />}
    </div>
  </article>

  <style>
    .floating-back-link {
      position: fixed;
      left: max(calc(var(--nav-width) + 32px), calc(50% - 390px));
      top: 24px;
      z-index: 40;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      background: rgba(10, 10, 10, 0.88);
      color: var(--color-white);
      backdrop-filter: blur(14px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.28);
      transition: transform var(--transition), border-color var(--transition), background-color var(--transition);
    }

    .floating-back-link:hover {
      transform: translateY(-1px);
      border-color: rgba(232, 213, 163, 0.32);
      background: rgba(18, 18, 18, 0.94);
    }

    .portfolio-detail-article {
      max-width: 780px;
      margin: 64px auto;
      padding: 0 64px 64px;
      min-width: 0;
    }

    .portfolio-detail-title {
      font-size: clamp(28px, 3vw, 48px);
      font-weight: 800;
      color: var(--color-white);
      letter-spacing: -0.03em;
      margin-bottom: 16px;
      line-height: 1.08;
      text-wrap: balance;
    }

    .portfolio-detail-desc {
      font-size: 16px;
      color: rgba(232, 232, 232, 0.62);
      margin-bottom: 24px;
      line-height: 1.7;
      max-width: 38rem;
    }

    .portfolio-detail-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 48px;
      padding-bottom: 48px;
      border-bottom: 1px solid var(--color-border);
    }

    .portfolio-detail-article h1,
    .portfolio-detail-article p,
    .portfolio-detail-article li,
    .portfolio-detail-article .prose {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .portfolio-detail-article .prose img,
    .portfolio-detail-article .prose iframe,
    .portfolio-detail-article .prose video,
    .portfolio-detail-article .prose canvas,
    .portfolio-detail-article .prose table {
      max-width: 100%;
    }

    .portfolio-detail-article .prose pre {
      max-width: 100%;
      overflow-x: auto;
    }

    .portfolio-detail-article .prose {
      color: rgba(232, 232, 232, 0.78);
      font-size: 15px;
      line-height: 1.82;
      max-width: 40rem;
    }

    .portfolio-detail-article .prose > :first-child {
      margin-top: 0;
    }

    .portfolio-detail-article .prose p,
    .portfolio-detail-article .prose li {
      max-width: none;
    }

    .portfolio-detail-article .prose h2 {
      font-size: clamp(24px, 2.2vw, 32px);
      line-height: 1.12;
      text-wrap: balance;
      margin-top: 2.1em;
      margin-bottom: 0.72em;
    }

    .portfolio-detail-article .prose h3 {
      margin-top: 1.8em;
      margin-bottom: 0.6em;
    }

    .portfolio-detail-article .prose img {
      border-radius: 12px;
      margin: 1.3em 0 1.5em;
    }

    @media (max-width: 900px) {
      .floating-back-link {
        left: 20px;
        top: 72px;
      }
    }

    @media (max-width: 768px) {
      .floating-back-link {
        position: static;
        margin: 16px 20px 0;
        width: fit-content;
        max-width: calc(100% - 40px);
      }

      .portfolio-detail-article {
        margin: 20px auto 0;
        padding: 0 20px 44px;
        max-width: 100%;
      }

      .portfolio-card-image-desktop {
        display: none;
      }

      .portfolio-detail-title {
        font-size: clamp(24px, 7.1vw, 32px);
        line-height: 1.08;
        letter-spacing: -0.04em;
        margin-bottom: 10px;
      }

      .portfolio-detail-desc {
        font-size: 13.5px;
        line-height: 1.62;
        margin-bottom: 22px;
      }

      .portfolio-card-tags {
        gap: 6px;
        margin-bottom: 12px !important;
      }

      .portfolio-detail-article .tag {
        max-width: 100%;
        padding: 4px 7px;
        font-size: 9px;
        letter-spacing: 0.05em;
        white-space: normal;
        overflow-wrap: anywhere;
      }

      .portfolio-detail-actions {
        margin-bottom: 32px;
        padding-bottom: 32px;
      }

      .portfolio-detail-article .prose {
        font-size: 15px;
        line-height: 1.72;
        max-width: 100%;
      }

      .portfolio-detail-article .prose h2 {
        font-size: clamp(21px, 6.4vw, 26px);
        line-height: 1.16;
      }

      .portfolio-detail-article .prose h3 {
        font-size: clamp(17px, 5.2vw, 21px);
        line-height: 1.22;
      }

      .portfolio-detail-article .prose p,
      .portfolio-detail-article .prose li {
        font-size: 15px;
      }

      .portfolio-detail-article .prose ul,
      .portfolio-detail-article .prose ol {
        padding-left: 1.2em;
      }

      .portfolio-detail-article .prose img {
        max-height: 52vh;
        object-fit: contain;
        background: rgba(255, 255, 255, 0.02);
      }

      .portfolio-detail-actions .btn-primary,
      .portfolio-detail-actions .btn-secondary {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</BaseLayout>
