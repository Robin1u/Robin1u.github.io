---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch and sort life data by date (newest first)
// 获取生活记录数据并按日期降序排列
const allLifePhotos = await getCollection('life');
const sortedPhotos = allLifePhotos.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---
<BaseLayout
  title="生活记录"
  titleEn="Life"
  description="Robin Lu 的生活记录页"
  descriptionEn="A page of life updates from Robin Lu"
  activePage="life"
>
  <section class="page-hero">
    <h1><I18nText zh="生活记录" en="Life" /></h1>
    <p><I18nText zh="一些日常碎片的记录与分享。" en="A few ordinary moments worth keeping and sharing." /></p>
  </section>

  <div class="life-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem;">
    {sortedPhotos.map((photo) => {
      const titleEn = photo.data.titleEn ?? photo.data.title;
      const captionEn = photo.data.captionEn ?? photo.data.caption;
      const dateCopy = formatLocalizedDate(photo.data.date);

      return (
        <article class:list={['life-card', { wide: photo.data.wide, tall: photo.data.tall }]}>
          <img
            src={photo.data.image}
            alt={photo.data.title}
            data-i18n-alt-zh={photo.data.title}
            data-i18n-alt-en={titleEn}
            loading="lazy"
            style="width: 100%; height: auto; border-radius: 8px; object-fit: cover;"
          />
          <div class="life-card-info" style="margin-top: 0.5rem;">
            <h3 style="font-size: 1rem; margin: 0;"><I18nText zh={photo.data.title} en={titleEn} /></h3>
            {photo.data.caption && captionEn && <p style="font-size: 0.875rem; color: #666; margin: 0.25rem 0;"><I18nText zh={photo.data.caption} en={captionEn} /></p>}
            <time style="font-size: 0.75rem; color: #999;"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></time>
          </div>
        </article>
      );
    })}
  </div>
</BaseLayout>
