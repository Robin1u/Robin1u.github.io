---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate, formatWeekLabel, recentCategoryLabels } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

const [homeEntry] = await getCollection('siteHome').catch(() => []);
const site = homeEntry?.data ?? {
  recentTitle: '最近在做',
  recentTitleEn: 'Recently Doing',
  recentItems: [],
};

const timelineItems = site.recentItems
  .slice()
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());

const allLifePhotos = await getCollection('life');
const sortedPhotos = allLifePhotos.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---
<BaseLayout
  title="生活记录"
  titleEn="Life"
  description="Robin Lu 的生活照片与日常痕迹"
  descriptionEn="Life photos and everyday traces from Robin Lu"
  activePage="life"
>
  <div class="life-layout">
    <div class="life-main">
      <section class="page-hero">
        <h1><I18nText zh="生活记录" en="Life" /></h1>
        <p>
          <I18nText
            zh="这里只保留生活痕迹本身：照片、片段、当下的场景与一句说明。"
            en="This page is reserved for the traces of everyday life itself: photos, moments, and a short note for each one."
          />
        </p>
      </section>

      {sortedPhotos.length > 0 ? (
        <div class="life-feed">
          {sortedPhotos.map((photo) => {
            const titleEn = photo.data.titleEn ?? photo.data.title;
            const captionEn = photo.data.captionEn ?? photo.data.caption;
            const dateCopy = formatLocalizedDate(photo.data.date);

            return (
              <article class="life-story-card">
                <div class="life-story-image">
                  <img
                    src={photo.data.image}
                    alt={photo.data.title}
                    data-i18n-alt-zh={photo.data.title}
                    data-i18n-alt-en={titleEn}
                    loading="lazy"
                  />
                </div>
                <div class="life-story-body">
                  <time class="life-story-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></time>
                  <h2 class="life-story-title"><I18nText zh={photo.data.title} en={titleEn} /></h2>
                  {photo.data.caption && (
                    <p class="life-story-caption"><I18nText zh={photo.data.caption} en={captionEn ?? photo.data.caption} /></p>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="quote-block" style="margin:32px 0;">
          <p class="quote-text"><I18nText zh="当前还没有生活照片内容。" en="No life photo posts yet." /></p>
        </div>
      )}
    </div>

    <aside class="life-sidebar">
      <div class="sidebar-widget life-timeline-widget">
        <div class="widget-title"><I18nText zh={site.recentTitle ?? '最近在做'} en={site.recentTitleEn ?? site.recentTitle ?? 'Recently Doing'} /></div>
        {timelineItems.length > 0 ? (
          <div class="life-timeline-list">
            {timelineItems.map((item) => {
              const categoryCopy = recentCategoryLabels[item.category];
              const weekCopy = formatWeekLabel(item.date);

              return (
                <article class:list={['life-timeline-item', { done: item.done }]}>
                  <div class="life-timeline-top">
                    <span class="life-timeline-category"><I18nText zh={categoryCopy.zh} en={categoryCopy.en} /></span>
                    <span class="life-timeline-week"><I18nText zh={weekCopy.zh} en={weekCopy.en} /></span>
                  </div>
                  <h3 class="life-timeline-title"><I18nText zh={item.title} en={item.titleEn ?? item.title} /></h3>
                  {item.subtitle && (
                    <p class="life-timeline-subtitle"><I18nText zh={item.subtitle} en={item.subtitleEn ?? item.subtitle} /></p>
                  )}
                  <div class="life-timeline-state">
                    <I18nText zh={item.done ? '已完成' : '进行中'} en={item.done ? 'Done' : 'In Progress'} />
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="quote-block" style="margin:16px 0 0;">
            <p class="quote-text"><I18nText zh="这里还没有最近在做的内容。" en="No recent items yet." /></p>
          </div>
        )}
      </div>
    </aside>
  </div>

  <style>
    .life-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.75fr);
      gap: 0;
      align-items: start;
      border-top: 1px solid var(--color-border);
    }

    .life-main {
      padding-right: 64px;
      border-right: 1px solid var(--color-border);
    }

    .life-sidebar {
      padding-left: 32px;
      position: sticky;
      top: 32px;
    }

    .life-feed {
      display: grid;
      gap: 24px;
    }

    .life-story-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-surface);
    }

    .life-story-image {
      aspect-ratio: 16 / 9;
      background: var(--color-surface-2);
      overflow: hidden;
    }

    .life-story-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .life-story-body {
      padding: 18px 20px 20px;
    }

    .life-story-date {
      display: block;
      font-size: 12px;
      color: var(--color-text-subtle);
      margin-bottom: 10px;
    }

    .life-story-title {
      margin: 0;
      font-size: clamp(22px, 2vw, 30px);
      color: var(--color-white);
      letter-spacing: -0.03em;
    }

    .life-story-caption {
      margin: 12px 0 0;
      color: var(--color-text-muted);
      font-size: 15px;
      line-height: 1.8;
    }

    .life-timeline-widget {
      padding-top: 72px;
    }

    .life-timeline-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
    }

    .life-timeline-item {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-surface);
      padding: 16px;
    }

    .life-timeline-item.done {
      opacity: 0.78;
    }

    .life-timeline-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      margin-bottom: 10px;
    }

    .life-timeline-category,
    .life-timeline-week,
    .life-timeline-state {
      font-size: 12px;
      color: var(--color-text-muted);
    }

    .life-timeline-title {
      margin: 0;
      font-size: 24px;
      color: var(--color-white);
    }

    .life-timeline-subtitle {
      margin: 8px 0 0;
      color: var(--color-text-muted);
      font-size: 14px;
    }

    .life-timeline-state {
      margin-top: 12px;
    }

    @media (max-width: 1024px) {
      .life-layout {
        grid-template-columns: 1fr;
      }

      .life-main {
        padding-right: 0;
        border-right: 0;
      }

      .life-sidebar {
        position: static;
        padding-left: 0;
        margin-top: 40px;
      }

      .life-timeline-widget {
        padding-top: 0;
      }
    }
  </style>
</BaseLayout>
