---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate, formatWeekLabel, recentCategoryLabels } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

const [homeEntry] = await getCollection('siteHome').catch(() => []);
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const site = homeEntry?.data ?? {
  recentTitle: '最近在做',
  recentTitleEn: 'Recently Doing',
  recentItems: [],
};
const lifePage = pagesEntry?.data?.life ?? {
  sectionNumber: '04',
  pageTitle: '生活记录',
  pageTitleEn: 'Life',
  intro: '这里只保留生活痕迹本身：照片、片段、当下的场景与一句说明。',
  introEn: 'This page is reserved for the traces of everyday life itself: photos, moments, and a short note for each one.',
};

const timelineItems = site.recentItems
  .slice()
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());

const lifePhotos = await getCollection('life').catch(() => []);
const sortedPhotos = lifePhotos.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---
<BaseLayout
  title={lifePage.pageTitle}
  titleEn={lifePage.pageTitleEn ?? lifePage.pageTitle}
  description="Robin Lu 的生活照片与日常痕迹"
  descriptionEn="Life photos and everyday traces from Robin Lu"
  activePage="life"
>
  <div class="thoughts-layout life-page-layout">
    <div class="thoughts-main">
      <div class="thoughts-header">
        <div class="section-header" style="margin-bottom:0;">
          <span class="section-number">{lifePage.sectionNumber}</span>
          <h1 class="section-title" style="font-size: clamp(32px,4vw,52px);">
            <I18nText zh={lifePage.pageTitle} en={lifePage.pageTitleEn ?? lifePage.pageTitle} />
          </h1>
          <div class="section-line"></div>
        </div>
        <p style="color:var(--color-text-muted); margin-top:16px; max-width:640px;">
          <I18nText zh={lifePage.intro} en={lifePage.introEn ?? lifePage.intro} />
        </p>
      </div>

      {sortedPhotos.length > 0 ? (
        <div class="life-feed">
          {sortedPhotos.map((photo) => {
            const titleEn = photo.data.titleEn ?? photo.data.title;
            const captionEn = photo.data.captionEn ?? photo.data.caption;
            const dateCopy = formatLocalizedDate(photo.data.date);

            return (
              <article class="life-story-card">
                <div class="life-story-image">
                  <img
                    src={photo.data.image}
                    alt={photo.data.title}
                    data-i18n-alt-zh={photo.data.title}
                    data-i18n-alt-en={titleEn}
                    loading="lazy"
                  />
                </div>
                <div class="life-story-body">
                  <time class="life-story-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></time>
                  {photo.data.location && (
                    <div class="life-story-location">
                      <I18nText zh={photo.data.location} en={photo.data.locationEn ?? photo.data.location} />
                    </div>
                  )}
                  <h2 class="life-story-title"><I18nText zh={photo.data.title} en={titleEn} /></h2>
                  {photo.data.caption && (
                    <p class="life-story-caption"><I18nText zh={photo.data.caption} en={captionEn ?? photo.data.caption} /></p>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="quote-block" style="margin:32px 64px;">
          <p class="quote-text"><I18nText zh="当前还没有生活照片内容。" en="No life photo posts yet." /></p>
        </div>
      )}
    </div>

    <aside class="thoughts-sidebar">
      <div class="sidebar-widget">
        <div class="widget-title"><I18nText zh={site.recentTitle ?? '最近在做'} en={site.recentTitleEn ?? site.recentTitle ?? 'Recently Doing'} /></div>
        {timelineItems.length > 0 ? (
          <div class="life-timeline-list">
            {timelineItems.map((item) => {
              const categoryCopy = recentCategoryLabels[item.category];
              const weekCopy = formatWeekLabel(item.date);

              return (
                <article class:list={['life-timeline-item', { done: item.done }]}>
                  <div class="life-timeline-top">
                    <span class="life-timeline-category"><I18nText zh={categoryCopy.zh} en={categoryCopy.en} /></span>
                    <span class="life-timeline-week"><I18nText zh={weekCopy.zh} en={weekCopy.en} /></span>
                  </div>
                  <h3 class="life-timeline-title"><I18nText zh={item.title} en={item.titleEn ?? item.title} /></h3>
                  {item.subtitle && (
                    <p class="life-timeline-subtitle"><I18nText zh={item.subtitle} en={item.subtitleEn ?? item.subtitle} /></p>
                  )}
                  <div class:list={['life-timeline-state', { done: item.done, active: !item.done }]}>
                    <span class="life-timeline-state-dot" aria-hidden="true"></span>
                    <I18nText zh={item.done ? '已完成' : '进行中'} en={item.done ? 'Done' : 'In Progress'} />
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="quote-block" style="margin:0;">
            <p class="quote-text"><I18nText zh="这里还没有最近在做的内容。" en="No recent items yet." /></p>
          </div>
        )}
      </div>
    </aside>
  </div>

  <style>
    .life-feed {
      padding: 32px 64px 64px;
      display: grid;
      gap: 24px;
    }

    .life-story-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: var(--color-surface);
    }

    .life-story-image {
      aspect-ratio: 16 / 9;
      background: var(--color-surface-2);
      overflow: hidden;
    }

    .life-story-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .life-story-body {
      padding: 18px 20px 20px;
    }

    .life-story-date {
      display: block;
      font-size: 12px;
      color: var(--color-text-subtle);
      margin-bottom: 6px;
    }

    .life-story-location {
      font-size: 12px;
      color: var(--color-text-muted);
      margin-bottom: 12px;
    }

    .life-story-title {
      margin: 0;
      font-size: clamp(22px, 2vw, 30px);
      color: var(--color-white);
      letter-spacing: -0.03em;
    }

    .life-story-caption {
      margin: 12px 0 0;
      color: var(--color-text-muted);
      font-size: 15px;
      line-height: 1.8;
    }

    .life-timeline-list {
      display: grid;
      gap: 14px;
      margin-top: 14px;
    }

    .life-timeline-item {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-surface);
      padding: 16px;
    }

    .life-timeline-item.done {
      opacity: 0.78;
    }

    .life-timeline-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      margin-bottom: 10px;
    }

    .life-timeline-category,
    .life-timeline-week,
    .life-timeline-state {
      font-size: 12px;
      color: var(--color-text-muted);
    }

    .life-timeline-week {
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .life-timeline-title {
      margin: 0;
      font-size: 24px;
      color: var(--color-white);
    }

    .life-timeline-subtitle {
      margin: 8px 0 0;
      color: var(--color-text-muted);
      font-size: 14px;
      line-height: 1.65;
    }

    .life-timeline-state {
      margin-top: 12px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .life-timeline-state.active {
      color: #7be495;
    }

    .life-timeline-state.done {
      color: var(--color-text-muted);
    }

    .life-timeline-state-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #7be495;
      box-shadow: 0 0 0 4px rgba(123, 228, 149, 0.08);
    }

    .life-timeline-state.done .life-timeline-state-dot {
      background: #121212;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    @media (max-width: 768px) {
      .life-feed {
        padding: 24px 20px 40px;
      }
    }
  </style>
</BaseLayout>
