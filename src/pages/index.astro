---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// 取最新 3 篇文章 + 精选项目（featured: true）
const allThoughts = await getCollection('thoughts', ({ data }) => !data.draft);
const allProjects = await getCollection('projects', ({ data }) => !data.draft);

const latestThoughts = allThoughts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Robin Lu" activePage="home">
  <div class="home-container">

    <!-- Hero 区域 -->
    <section class="hero-section">
      <div class="hero-status">
        <span class="status-dot"></span>
        <span>现在在柏林 · 学生 / 设计师 / 开发者</span>
      </div>
      <h1 class="hero-title">
        用设计思维<br />写能用的代码
      </h1>
      <p class="hero-desc">
        我在学习的交叉点上工作 —— 用户体验、前端开发与系统思考。
        这里记录我真实在做的东西，而不是精心包装过的简历。
      </p>
      <div class="hero-actions">
        <a href="/portfolio" class="btn-primary">查看作品集</a>
        <a href="/thoughts" class="btn-ghost">阅读文章 →</a>
      </div>
    </section>

    <!-- 精选项目 -->
    {featuredProjects.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="section-title">精选项目</h2>
          <a href="/portfolio" class="section-link">全部作品 →</a>
        </div>
        <div class="featured-grid">
          {featuredProjects.map(project => (
            <a href={`/portfolio/${project.id}`} class="featured-card">
              <div class="featured-card-img">
                {project.data.image
                  ? <img src={project.data.image} alt={project.data.title} loading="lazy" width="400" height="225" />
                  : <div class="img-placeholder">{project.data.title.slice(0,2).toUpperCase()}</div>
                }
              </div>
              <div class="featured-card-body">
                <div class="portfolio-card-tags">
                  <span class="tag accent">
                    {project.data.category === 'web' ? 'Web 应用'
                    : project.data.category === 'design' ? '设计系统'
                    : project.data.category === 'tool' ? '工具' : '移动端'}
                  </span>
                </div>
                <h3 class="featured-card-title">{project.data.title}</h3>
                <p class="featured-card-desc">{project.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 最新文章 -->
    {latestThoughts.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="section-title">最新想法</h2>
          <a href="/thoughts" class="section-link">全部文章 →</a>
        </div>
        <div class="thoughts-list">
          {latestThoughts.map(post => (
            <a href={`/thoughts/${post.id}`} class="thought-row">
              <div class="thought-row-left">
                <span class="thought-cat">{post.data.category}</span>
                <h3 class="thought-title">{post.data.title}</h3>
                <p class="thought-desc">{post.data.description}</p>
              </div>
              <div class="thought-row-right">
                <span class="post-date">{post.data.date.toLocaleDateString('zh-CN')}</span>
                <span class="thought-read">{post.data.readTime} min</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
.home-container {
  padding: 64px 64px 80px;
  max-width: 900px;
  display: flex;
  flex-direction: column;
  gap: 72px;
}

/* Hero */
.hero-section { display: flex; flex-direction: column; gap: 20px; }

.hero-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--color-text-muted);
  letter-spacing: 0.02em;
}
.status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 6px #4ade80;
  flex-shrink: 0;
}

.hero-title {
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 800;
  color: var(--color-white);
  letter-spacing: -0.03em;
  line-height: 1.1;
}

.hero-desc {
  font-size: 15px;
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 52ch;
}

.hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  padding-top: 4px;
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 8px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text-muted);
  border: 1px solid rgba(255,255,255,0.1);
  text-decoration: none;
  transition: all 180ms ease;
}
.btn-ghost:hover {
  color: var(--color-white);
  border-color: rgba(255,255,255,0.25);
}

/* 通用 section */
.home-section { display: flex; flex-direction: column; gap: 24px; }

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.section-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.section-link {
  font-size: 12px;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color 180ms ease;
}
.section-link:hover { color: var(--color-white); }

/* 精选项目网格 */
.featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
}
.featured-card {
  display: flex;
  flex-direction: column;
  border-radius: 10px;
  overflow: hidden;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  text-decoration: none;
  transition: border-color 200ms ease, transform 200ms ease;
}
.featured-card:hover {
  border-color: rgba(255,255,255,0.15);
  transform: translateY(-2px);
}
.featured-card-img {
  aspect-ratio: 16/9;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
}
.featured-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 300ms ease;
}
.featured-card:hover .featured-card-img img { transform: scale(1.04); }

.featured-card-body { padding: 16px; display: flex; flex-direction: column; gap: 6px; }
.featured-card-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--color-white);
  line-height: 1.3;
}
.featured-card-desc {
  font-size: 12px;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* 最新文章列表 */
.thoughts-list { display: flex; flex-direction: column; }
.thought-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24px;
  padding: 20px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  text-decoration: none;
  transition: opacity 180ms ease;
}
.thought-row:first-child { padding-top: 0; }
.thought-row:hover { opacity: 0.7; }
.thought-row-left { display: flex; flex-direction: column; gap: 4px; flex: 1; }
.thought-cat {
  font-size: 11px;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.thought-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-white);
  line-height: 1.3;
}
.thought-desc {
  font-size: 12px;
  color: var(--color-text-muted);
  line-height: 1.5;
  max-width: 55ch;
}
.thought-row-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}
.thought-read {
  font-size: 11px;
  color: var(--color-text-muted);
}

@media (max-width: 640px) {
  .home-container { padding: 32px 24px 60px; gap: 48px; }
  .featured-grid { grid-template-columns: 1fr; }
  .thought-row { flex-direction: column; gap: 8px; }
  .thought-row-right { flex-direction: row; align-items: center; }
}
</style>