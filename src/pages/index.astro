---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate, formatWeekLabel, projectCategoryLabels, recentCategoryLabels } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

const [siteEntry] = await getCollection('siteHome').catch(() => []);
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const site = siteEntry?.data ?? {
  name: 'Robin Lu',
  nameEn: 'Robin Lu',
  heroTag: '开放合作机会',
  heroTagEn: 'Open for collaboration',
  status: '现在在柏林',
  statusEn: 'Currently in Berlin',
  roles: [],
  heroLeadPrefix: '一名在柏林学习设计与工程的',
  heroLeadPrefixEn: 'A',
  heroTypingWord: '学生',
  heroTypingWordEn: 'student',
  heroLeadSuffix: '，',
  heroLeadSuffixEn: ' based in Berlin,',
  heroLeadSecondLine: '也持续把想法做成项目、文字与表达。',
  heroLeadSecondLineEn: 'while continuously turning ideas into projects, writing, and expression.',
  heroDescriptionParagraphs: [
    {
      zh: '这里记录我的作品、观察，以及日常生活里那些值得被留下来的片段。',
      en: 'This is where I keep my work, observations, and the fragments of everyday life worth holding onto.',
    },
  ],
  aboutTitle: '关于我',
  aboutTitleEn: 'About Me',
  aboutParagraphs: [],
  recentTitle: '最近在做',
  recentTitleEn: 'Recently Doing',
  recentItems: [],
};
const sitePages = pagesEntry?.data ?? {
  portfolio: {
    sectionNumber: '02',
    navLabel: '作品集',
    navLabelEn: 'Portfolio',
  },
  thoughts: {
    sectionNumber: '03',
    navLabel: '想法',
    navLabelEn: 'Thoughts',
  },
  life: {
    sectionNumber: '04',
    navLabel: '生活',
    navLabelEn: 'Life',
  },
};

const activeRecentItems = site.recentItems.filter((item) => !item.done);
const recentItemsPreview = activeRecentItems.length > 0
  ? activeRecentItems.slice(0, 3)
  : site.recentItems.slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const thoughts = (await getCollection('thoughts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const life = (await getCollection('life'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredProjects = projects.filter((project) => project.data.featured).length > 0
  ? projects.filter((project) => project.data.featured).slice(0, 3)
  : projects.slice(0, 3);
const featuredThoughts = thoughts.filter((post) => post.data.featured).length > 0
  ? thoughts.filter((post) => post.data.featured).slice(0, 2)
  : thoughts.slice(0, 2);
const featuredLife = life.slice(0, 2);

const rolesZh = site.roles.map((role) => role.zh).join(' / ');
const rolesEn = site.roles.map((role) => role.en ?? role.zh).join(' / ');
const statusLineZh = rolesZh ? `${site.status} · ${rolesZh}` : site.status;
const statusLineEn = rolesEn ? `${site.statusEn ?? site.status} · ${rolesEn}` : (site.statusEn ?? site.status);
const typingWordZh = site.heroTypingWord ?? '学生';
const typingWordEn = site.heroTypingWordEn ?? 'student';
const typingWordsZh = JSON.stringify([typingWordZh]);
const typingWordsEn = JSON.stringify([typingWordEn]);
---
<BaseLayout
  title="首页"
  titleEn="Home"
  description="Robin Lu 的个人主页首页"
  descriptionEn="Home page of Robin Lu's personal website"
  activePage="home"
>
  <section class="hero" aria-label="站点介绍">
    <div class="hero-tag">
      <I18nText zh={site.heroTag ?? '开放合作机会'} en={site.heroTagEn ?? site.heroTag ?? 'Open for collaboration'} />
    </div>
    <div class="hero-status">
      <span class="status-dot"></span>
      <I18nText zh={statusLineZh} en={statusLineEn} />
    </div>
    <p class="hero-greeting">
      <I18nText zh="你好，我是" en="Hello, I'm" />
    </p>
    <h1 class="hero-name">
      <I18nText zh={site.name} en={site.nameEn ?? site.name} />
    </h1>
    <div class="hero-copy">
      <p class="hero-lead">
        <I18nText zh={site.heroLeadPrefix ?? ''} en={site.heroLeadPrefixEn ?? site.heroLeadPrefix ?? ''} />
        <span
          id="typingText"
          class="typing-word"
          data-words-zh={typingWordsZh}
          data-words-en={typingWordsEn}
        >
          {typingWordZh}
        </span>
        <span class="typing-cursor" aria-hidden="true"></span>
        <I18nText zh={site.heroLeadSuffix ?? ''} en={site.heroLeadSuffixEn ?? site.heroLeadSuffix ?? ''} />
        <br />
        <I18nText zh={site.heroLeadSecondLine ?? ''} en={site.heroLeadSecondLineEn ?? site.heroLeadSecondLine ?? ''} />
      </p>
      <div class="hero-summary">
        {site.heroDescriptionParagraphs.map((paragraph) => (
          <p><I18nText zh={paragraph.zh} en={paragraph.en ?? paragraph.zh} /></p>
        ))}
      </div>
    </div>
    <div class="hero-cta">
      <a href="/portfolio" class="btn-primary">
        <I18nText zh="查看作品集" en="View Portfolio" />
      </a>
      <a href="/channel" class="btn-secondary">
        <I18nText zh="打开频道" en="Open Channels" />
      </a>
    </div>
  </section>

  <div class="stats-bar" role="list">
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={projects.length} data-suffix="">0</span></div>
      <div class="stat-label"><I18nText zh="项目" en="Projects" /></div>
    </div>
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={thoughts.length} data-suffix="">0</span></div>
      <div class="stat-label"><I18nText zh="文章" en="Posts" /></div>
    </div>
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={life.length} data-suffix="">0</span></div>
      <div class="stat-label"><I18nText zh="生活记录" en="Life Logs" /></div>
    </div>
  </div>

  <section class="about-section" aria-label="关于我">
    <div class="section-header">
      <span class="section-number">01</span>
      <h2 class="section-title"><I18nText zh={site.aboutTitle} en={site.aboutTitleEn ?? site.aboutTitle} /></h2>
      <div class="section-line"></div>
    </div>

    <div class="about-grid">
      <div class="about-text">
        {site.aboutParagraphs.map((paragraph) => (
          <p><I18nText zh={paragraph.zh} en={paragraph.en ?? paragraph.zh} /></p>
        ))}
      </div>

      <div class="now-panel">
        <div class="widget-title" style="margin-bottom:16px;">
          <I18nText zh={site.recentTitle} en={site.recentTitleEn ?? site.recentTitle} />
        </div>
        {recentItemsPreview.length > 0 ? (
          <div class="now-list">
            {recentItemsPreview.map((item) => {
              const categoryCopy = recentCategoryLabels[item.category];
              const weekCopy = formatWeekLabel(item.date);

              return (
                <article class:list={['now-card', { done: item.done }]}>
                  <div class="now-card-meta">
                    <span class="now-card-label">
                      <I18nText zh={categoryCopy.zh} en={categoryCopy.en} />
                    </span>
                    <div class="now-card-badges">
                      <span class="now-card-week">
                        <I18nText zh={weekCopy.zh} en={weekCopy.en} />
                      </span>
                    </div>
                  </div>
                  <h3 class="now-card-title"><I18nText zh={item.title} en={item.titleEn ?? item.title} /></h3>
                  {item.subtitle && (
                    <p class="now-card-subtitle">
                      <I18nText zh={item.subtitle} en={item.subtitleEn ?? item.subtitle} />
                    </p>
                  )}
                  <div class:list={['now-card-state', { done: item.done, active: !item.done }]}>
                    <span class="now-card-state-dot" aria-hidden="true"></span>
                    <I18nText zh={item.done ? '已完成' : '进行中'} en={item.done ? 'Done' : 'In Progress'} />
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="quote-block" style="margin:0;">
            <p class="quote-text"><I18nText zh="这里还没有最近在做的内容。" en="No recent items yet." /></p>
          </div>
        )}
      </div>
    </div>

    <div class="about-secret">
      <a
        href="/lucky-cat"
        class="secret-cat-link"
        aria-label="Cat Entrance"
        data-i18n-title-zh="猫咪入口"
        data-i18n-title-en="Cat Entrance"
        title="猫咪入口"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M6 10.5c0-4 2.8-6.5 6-6.5s6 2.5 6 6.5c0 5-2.5 8.5-6 8.5s-6-3.5-6-8.5z"></path>
          <path d="M8 5 6 2.8 5.4 7M16 5l2-2.2.6 4.2"></path>
          <circle cx="10" cy="11" r=".9" fill="currentColor" stroke="none"></circle>
          <circle cx="14" cy="11" r=".9" fill="currentColor" stroke="none"></circle>
          <path d="M10 14c.6.5 1.3.8 2 .8s1.4-.3 2-.8"></path>
        </svg>
      </a>
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="works-preview" aria-label="最新项目">
      <div class="section-header">
        <span class="section-number">{sitePages.portfolio.sectionNumber}</span>
        <h2 class="section-title">
          <I18nText
            zh={sitePages.portfolio.navLabel}
            en={sitePages.portfolio.navLabelEn ?? sitePages.portfolio.navLabel}
          />
        </h2>
        <div class="section-line"></div>
      </div>

      <div class="works-grid">
        {featuredProjects.map((project) => {
          const titleEn = project.data.titleEn ?? project.data.title;
          const descriptionEn = project.data.descriptionEn ?? project.data.description;
          const categoryCopy = project.data.category ? projectCategoryLabels[project.data.category] : undefined;

          return (
            <a href={`/portfolio/${project.id}`} class="work-card">
              <div class="work-card-thumb">
                {project.data.image
                  ? (
                    <img
                      src={project.data.image}
                      alt={project.data.title}
                      data-i18n-alt-zh={project.data.title}
                      data-i18n-alt-en={titleEn}
                      loading="lazy"
                    />
                  )
                  : (
                    <I18nText
                      as="div"
                      class="thumb-placeholder"
                      zh={project.data.title.slice(0, 2)}
                      en={titleEn.slice(0, 2)}
                    />
                  )}
              </div>
              <div class="work-card-body">
                {categoryCopy && <div class="work-card-tag"><I18nText zh={categoryCopy.zh} en={categoryCopy.en} /></div>}
                <h3 class="work-card-title"><I18nText zh={project.data.title} en={titleEn} /></h3>
                {project.data.description && descriptionEn && <p class="work-card-desc"><I18nText zh={project.data.description} en={descriptionEn} /></p>}
              </div>
            </a>
          );
        })}
      </div>

      <a href="/portfolio" class="view-all-link">
        <I18nText zh="查看全部项目" en="View All Projects" />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </section>
  )}

  {featuredThoughts.length > 0 && (
    <section class="content-preview" aria-label="最新文章">
      <div class="section-header">
        <span class="section-number">{sitePages.thoughts.sectionNumber}</span>
        <h2 class="section-title">
          <I18nText
            zh={sitePages.thoughts.navLabel}
            en={sitePages.thoughts.navLabelEn ?? sitePages.thoughts.navLabel}
          />
        </h2>
        <div class="section-line"></div>
      </div>

      <div class="content-grid">
        {featuredThoughts.map((post) => {
          const dateCopy = formatLocalizedDate(post.data.date);

          return (
            <a href={`/thoughts/${post.id}`} class="content-card content-card-text">
              <div class="content-card-meta">
                <span><I18nText zh={dateCopy.zh} en={dateCopy.en} /></span>
                {post.data.category && <span class="content-chip">{post.data.category}</span>}
              </div>
              <h3 class="content-card-title"><I18nText zh={post.data.title} en={post.data.titleEn ?? post.data.title} /></h3>
              {post.data.description && (
                <p class="content-card-desc">
                  <I18nText zh={post.data.description} en={post.data.descriptionEn ?? post.data.description} />
                </p>
              )}
              {(post.data.tags ?? []).length > 0 && (
                <div class="content-card-tags">
                  {(post.data.tags ?? []).slice(0, 3).map((tag) => <span class="content-chip">{tag}</span>)}
                </div>
              )}
            </a>
          );
        })}
      </div>

      <a href="/thoughts" class="view-all-link">
        <I18nText zh="查看全部文章" en="View All Posts" />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </section>
  )}

  {featuredLife.length > 0 && (
    <section class="content-preview" aria-label="最新生活记录">
      <div class="section-header">
        <span class="section-number">{sitePages.life.sectionNumber}</span>
        <h2 class="section-title">
          <I18nText
            zh={sitePages.life.navLabel}
            en={sitePages.life.navLabelEn ?? sitePages.life.navLabel}
          />
        </h2>
        <div class="section-line"></div>
      </div>

      <div class="content-grid">
        {featuredLife.map((entry) => {
          const dateCopy = formatLocalizedDate(entry.data.date);

          return (
            <a href="/life" class="content-card content-card-photo">
              <div class="content-card-image">
                <img
                  src={entry.data.image}
                  alt={entry.data.title}
                  data-i18n-alt-zh={entry.data.title}
                  data-i18n-alt-en={entry.data.titleEn ?? entry.data.title}
                  loading="lazy"
                />
              </div>
              <div class="content-card-body">
                <div class="content-card-meta">
                  <span><I18nText zh={dateCopy.zh} en={dateCopy.en} /></span>
                  {entry.data.location && (
                    <span class="content-chip">
                      <I18nText zh={entry.data.location} en={entry.data.locationEn ?? entry.data.location} />
                    </span>
                  )}
                </div>
                <h3 class="content-card-title"><I18nText zh={entry.data.title} en={entry.data.titleEn ?? entry.data.title} /></h3>
                {entry.data.caption && (
                  <p class="content-card-desc">
                    <I18nText zh={entry.data.caption} en={entry.data.captionEn ?? entry.data.caption} />
                  </p>
                )}
              </div>
            </a>
          );
        })}
      </div>

      <a href="/life" class="view-all-link">
        <I18nText zh="查看全部生活记录" en="View All Life Posts" />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </section>
  )}

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/portfolio"><I18nText zh="作品集" en="Portfolio" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
      <a href="/channel"><I18nText zh="频道" en="Channels" /></a>
    </nav>
  </footer>

  <style>
    .hero-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
      font-size: 13px;
      color: var(--color-text-muted);
    }

    .hero-copy {
      display: grid;
      gap: 18px;
      margin-bottom: 28px;
    }

    .hero-lead {
      margin: 0;
      max-width: 760px;
      font-size: clamp(24px, 3vw, 34px);
      line-height: 1.45;
      color: var(--color-white);
      letter-spacing: -0.03em;
    }

    .typing-word {
      display: inline-block;
      min-width: 1ch;
      color: var(--color-accent);
      font-weight: 700;
    }

    .typing-cursor {
      display: inline-block;
      width: 1px;
      height: 0.95em;
      margin: 0 5px 0 2px;
      background: currentColor;
      vertical-align: -0.12em;
      animation: blink-cursor 0.9s steps(1) infinite;
    }

    .hero-summary {
      display: grid;
      gap: 8px;
      max-width: 760px;
    }

    .hero-summary p {
      margin: 0;
      font-size: 16px;
      line-height: 1.9;
      color: var(--color-text-muted);
    }

    .now-panel {
      display: flex;
      flex-direction: column;
    }

    .now-list {
      display: grid;
      gap: 14px;
    }

    .now-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-surface);
      padding: 18px 18px 16px;
      transition: border-color var(--transition), transform var(--transition), opacity var(--transition);
    }

    .now-card:hover {
      border-color: var(--color-text-subtle);
      transform: translateY(-2px);
    }

    .now-card-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .now-card-badges {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .now-card-label {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-subtle);
      font-weight: 700;
    }

    .now-card-week {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-muted);
    }

    .now-card-title {
      font-size: 22px;
      line-height: 1.2;
      color: var(--color-white);
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .now-card-subtitle {
      font-size: 14px;
      line-height: 1.5;
      color: var(--color-text-muted);
    }

    .now-card-state {
      margin-top: 14px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--color-text-muted);
    }

    .now-card-state-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #7be495;
      box-shadow: 0 0 0 4px rgba(123, 228, 149, 0.08);
    }

    .now-card-state.done .now-card-state-dot {
      background: #121212;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    .about-secret {
      display: flex;
      justify-content: flex-end;
      margin-top: 18px;
    }

    .secret-cat-link {
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 999px;
      color: rgba(255, 255, 255, 0.28);
      transition: transform var(--transition), border-color var(--transition), color var(--transition), background var(--transition);
    }

    .secret-cat-link:hover {
      color: var(--color-accent);
      border-color: rgba(232, 214, 158, 0.32);
      background: rgba(232, 214, 158, 0.05);
      transform: translateY(-2px);
    }

    .secret-cat-link svg {
      width: 18px;
      height: 18px;
    }

    .content-preview {
      padding: 72px 64px;
      border-top: 1px solid var(--color-border);
    }

    @keyframes blink-cursor {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }

    .content-card {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      background: var(--color-surface);
      overflow: hidden;
      transition: border-color var(--transition), transform var(--transition);
    }

    .content-card:hover {
      border-color: var(--color-text-subtle);
      transform: translateY(-2px);
    }

    .content-card-text {
      padding: 22px 22px 20px;
      justify-content: space-between;
    }

    .content-card-meta,
    .content-card-tags {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .content-card-meta {
      font-size: 12px;
      color: var(--color-text-subtle);
      margin-bottom: 14px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .content-card-title {
      margin: 0;
      font-size: clamp(22px, 2vw, 30px);
      line-height: 1.15;
      color: var(--color-white);
      letter-spacing: -0.03em;
    }

    .content-card-desc {
      margin: 12px 0 0;
      font-size: 14px;
      line-height: 1.75;
      color: var(--color-text-muted);
    }

    .content-chip {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      padding: 0 10px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.02);
      color: var(--color-text-subtle);
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .content-card-tags {
      margin-top: 18px;
    }

    .content-card-image {
      aspect-ratio: 16 / 10;
      background: var(--color-surface-2);
      overflow: hidden;
    }

    .content-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .content-card-body {
      padding: 18px 20px 20px;
    }

    @media (max-width: 768px) {
      .hero-lead {
        font-size: 22px;
      }

      .hero-summary p {
        font-size: 15px;
      }

      .content-preview {
        padding: 56px 24px;
      }

      .content-grid {
        grid-template-columns: 1fr;
      }

      .now-card-title {
        font-size: 18px;
      }
    }
  </style>
</BaseLayout>
