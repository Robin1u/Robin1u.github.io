---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';
import { formatLocalizedDate, projectCategoryLabels } from '../lib/i18n';
import BaseLayout from '../layouts/BaseLayout.astro';

async function safeGetCollection(name) {
  try {
    return await getCollection(name, ({ data }) => !data.draft);
  } catch {
    return [];
  }
}

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const thoughts = (await safeGetCollection('thoughts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const life = (await getCollection('life'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredProjects = projects.filter((project) => project.data.featured).length > 0
  ? projects.filter((project) => project.data.featured).slice(0, 3)
  : projects.slice(0, 3);

const latestThoughts = thoughts.slice(0, 3);
const latestLife = life.slice(0, 3);
---
<BaseLayout
  title="首页"
  titleEn="Home"
  description="Robin Lu 的个人主页首页"
  descriptionEn="Home page of Robin Lu's personal website"
  activePage="home"
>
  <section class="hero" aria-label="站点介绍">
    <div class="hero-tag">
      <I18nText zh="网站框架已接入" en="Framework Ready" />
    </div>
    <p class="hero-greeting">
      <I18nText zh="当前站点" en="Current site" />
    </p>
    <h1 class="hero-name">
      <I18nText as="span" class="hero-name-base" zh="内容驱动的 " en="A content-driven " />
      <I18nText as="span" class="hero-name-accent" zh="个人主页" en="personal site" />
    </h1>
    <p class="hero-subtitle">
      <I18nText
        zh="保留现有内容数据，使用新的页面框架、导航结构与路由组织方式。"
        en="Keep the existing content data while rebuilding the site with a clearer layout, navigation, and routing structure."
      />
    </p>
    <div class="hero-cta">
      <a href="/portfolio" class="btn-primary">
        <I18nText zh="查看内容" en="Explore Work" />
      </a>
      <a href="/thoughts" class="btn-secondary">
        <I18nText zh="浏览想法" en="Read Thoughts" />
      </a>
    </div>
  </section>

  <div class="stats-bar" role="list">
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={projects.length} data-suffix="">0</span></div>
      <div class="stat-label">
        <I18nText zh="项目" en="Projects" />
      </div>
    </div>
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={thoughts.length} data-suffix="">0</span></div>
      <div class="stat-label">
        <I18nText zh="文章" en="Posts" />
      </div>
    </div>
    <div class="stat-item" role="listitem">
      <div class="stat-number"><span data-count={life.length} data-suffix="">0</span></div>
      <div class="stat-label">
        <I18nText zh="生活记录" en="Life Logs" />
      </div>
    </div>
  </div>

  {featuredProjects.length > 0 && (
    <section class="works-preview" aria-label="最新项目">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">
          <I18nText zh="项目" en="Projects" />
        </h2>
        <div class="section-line"></div>
      </div>

      <div class="works-grid">
        {featuredProjects.map((project) => {
          const titleEn = project.data.titleEn ?? project.data.title;
          const descriptionEn = project.data.descriptionEn ?? project.data.description;
          const categoryCopy = project.data.category ? projectCategoryLabels[project.data.category] : undefined;

          return (
            <a href={`/portfolio/${project.id}`} class="work-card">
              <div class="work-card-thumb">
                {project.data.image
                  ? (
                    <img
                      src={project.data.image}
                      alt={project.data.title}
                      data-i18n-alt-zh={project.data.title}
                      data-i18n-alt-en={titleEn}
                      loading="lazy"
                    />
                  )
                  : (
                    <I18nText
                      as="div"
                      class="thumb-placeholder"
                      zh={project.data.title.slice(0, 2)}
                      en={titleEn.slice(0, 2)}
                    />
                  )}
              </div>
              <div class="work-card-body">
                {categoryCopy && <div class="work-card-tag"><I18nText zh={categoryCopy.zh} en={categoryCopy.en} /></div>}
                <h3 class="work-card-title"><I18nText zh={project.data.title} en={titleEn} /></h3>
                {project.data.description && descriptionEn && <p class="work-card-desc"><I18nText zh={project.data.description} en={descriptionEn} /></p>}
              </div>
            </a>
          );
        })}
      </div>

      <a href="/portfolio" class="view-all-link">
        <I18nText zh="查看全部项目" en="View All Projects" />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </section>
  )}

  {(latestThoughts.length > 0 || latestLife.length > 0) && (
    <section class="about-section" aria-label="近期更新">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">
          <I18nText zh="近期更新" en="Recent Updates" />
        </h2>
        <div class="section-line"></div>
      </div>

      <div class="about-grid">
        <div>
          <div class="widget-title" style="margin-bottom:16px;">
            <I18nText zh="文章" en="Posts" />
          </div>
          {latestThoughts.length > 0 ? (
            <div class="post-list" style="border:1px solid var(--color-border); border-radius: var(--radius-md); overflow:hidden;">
              {latestThoughts.map((post) => {
                const dateCopy = formatLocalizedDate(post.data.date);

                return (
                  <a href={`/thoughts/${post.id}`} class="post-item" style="padding:20px 24px; display:block;">
                    <div class="post-item-meta">
                      <span class="post-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></span>
                      {post.data.category && <span class="post-category">{post.data.category}</span>}
                    </div>
                    <h3>{post.data.title}</h3>
                    {post.data.description && <p>{post.data.description}</p>}
                  </a>
                );
              })}
            </div>
          ) : (
            <div class="quote-block"><p class="quote-text"><I18nText zh="当前还没有文章内容。" en="No posts yet." /></p></div>
          )}
        </div>

        <div>
          <div class="widget-title" style="margin-bottom:16px;">
            <I18nText zh="生活" en="Life" />
          </div>
          {latestLife.length > 0 ? (
            <div class="life-grid" style="padding:0; grid-template-columns:1fr; gap:12px;">
              {latestLife.map((item) => {
                const titleEn = item.data.titleEn ?? item.data.title;
                const captionEn = item.data.captionEn ?? item.data.caption;
                const dateCopy = formatLocalizedDate(item.data.date);

                return (
                  <article class="life-card">
                    <div class="life-card-img" style="aspect-ratio:16/9;">
                      <img
                        src={item.data.image}
                        alt={item.data.title}
                        data-i18n-alt-zh={item.data.title}
                        data-i18n-alt-en={titleEn}
                        loading="lazy"
                      />
                    </div>
                    <div class="life-card-body">
                      <div class="life-card-date"><I18nText zh={dateCopy.zh} en={dateCopy.en} /></div>
                      <div class="life-card-title"><I18nText zh={item.data.title} en={titleEn} /></div>
                      {item.data.caption && captionEn && <div class="life-card-caption"><I18nText zh={item.data.caption} en={captionEn} /></div>}
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <div class="quote-block"><p class="quote-text"><I18nText zh="当前还没有生活记录。" en="No life updates yet." /></p></div>
          )}
        </div>
      </div>
    </section>
  )}

  <footer class="page-footer">
    <span class="footer-copy">© 2026 Robin Lu</span>
    <nav class="footer-links">
      <a href="/portfolio"><I18nText zh="作品集" en="Portfolio" /></a>
      <a href="/thoughts"><I18nText zh="想法" en="Thoughts" /></a>
      <a href="/life"><I18nText zh="生活" en="Life" /></a>
      <a href="/channel"><I18nText zh="频道" en="Channels" /></a>
    </nav>
  </footer>
</BaseLayout>
