---
import { getCollection } from 'astro:content';
import I18nText from '../components/I18nText.astro';

export interface Props {
  title: string;
  titleEn?: string;
  description?: string;
  descriptionEn?: string;
  activePage?: 'home' | 'portfolio' | 'thoughts' | 'channel' | 'life' | 'cat' | '404';
}

const {
  title,
  titleEn = title,
  description = '个人主页',
  descriptionEn = 'Personal website',
  activePage = 'home',
} = Astro.props;

const pageTitleZh = `${title} · Robin Lu`;
const pageTitleEn = `${titleEn} · Robin Lu`;

const [homeEntry] = await getCollection('siteHome').catch(() => []);
const [pagesEntry] = await getCollection('sitePages').catch(() => []);
const siteSettings = homeEntry?.data ?? {
  name: 'Robin Lu',
  nameEn: 'Robin Lu',
  roles: [],
  contactEmail: '',
  findMeLinks: [],
};
const pageSettings = pagesEntry?.data ?? {
  home: { navLabel: '首页', navLabelEn: 'Home' },
  portfolio: { navLabel: '作品集', navLabelEn: 'Portfolio' },
  thoughts: { navLabel: '想法', navLabelEn: 'Thoughts' },
  life: { navLabel: '生活', navLabelEn: 'Life' },
  channel: { navLabel: '频道', navLabelEn: 'Channels' },
};

const sidebarNameZh = siteSettings.name;
const sidebarNameEn = siteSettings.nameEn ?? siteSettings.name;
const sidebarTitleZh = siteSettings.roles.length > 0
  ? siteSettings.roles.map((role) => role.zh).join(' / ')
  : '个人主页';
const sidebarTitleEn = siteSettings.roles.length > 0
  ? siteSettings.roles.map((role) => role.en ?? role.zh).join(' / ')
  : 'Personal site';
const rawContactEmail = siteSettings.contactEmail?.trim() ?? '';
const normalizedContactEmail = rawContactEmail.replace(/^mailto:/i, '').trim();
const contactEmail = normalizedContactEmail;
const contactEmailHref = normalizedContactEmail ? `mailto:${normalizedContactEmail}` : '';
const findMeLinks = siteSettings.findMeLinks ?? [];
const socialPlatformLabels = {
  github: { zh: 'GitHub', en: 'GitHub' },
  linkedin: { zh: 'LinkedIn', en: 'LinkedIn' },
  huggingface: { zh: 'Hugging Face', en: 'Hugging Face' },
  website: { zh: '网站', en: 'Website' },
};
---
<!DOCTYPE html>
<html lang="zh-CN" data-language="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta id="metaDescription" name="description" content={description} />
  <meta name="theme-color" content="#0a0a0a" />
  <title>{pageTitleZh}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script is:inline>
    (() => {
      try {
        const saved = localStorage.getItem('site-language');
        if (saved === 'zh' || saved === 'en') {
          document.documentElement.dataset.language = saved;
          document.documentElement.lang = saved === 'en' ? 'en' : 'zh-CN';
        }
      } catch {
      }
    })();
  </script>
</head>
<body
  data-page-title-zh={pageTitleZh}
  data-page-title-en={pageTitleEn}
  data-page-description-zh={description}
  data-page-description-en={descriptionEn}
>
  <div class="scroll-progress" id="scrollProgress"></div>

  <header class="mobile-header">
    <span class="mobile-header-name">
      <I18nText zh={sidebarNameZh} en={sidebarNameEn} />
    </span>
    <div class="mobile-header-actions">
      <div
        class="language-switch"
        role="group"
        aria-label="语言切换"
        data-i18n-aria-label-zh="语言切换"
        data-i18n-aria-label-en="Language switch"
      >
        <button type="button" class="language-btn" data-set-language="zh">中</button>
        <button type="button" class="language-btn" data-set-language="en">EN</button>
      </div>
      <button
        class="mobile-menu-btn"
        id="menuBtn"
        aria-label="打开菜单"
        data-i18n-aria-label-zh="打开菜单"
        data-i18n-aria-label-en="Open menu"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="overlay" id="overlay"></div>

  <div class="layout">
    <aside
      class="sidebar"
      id="sidebar"
      role="navigation"
      aria-label="主导航"
      data-i18n-aria-label-zh="主导航"
      data-i18n-aria-label-en="Primary navigation"
    >
      <div class="sidebar-logo">
        <div class="name">
          <I18nText zh={sidebarNameZh} en={sidebarNameEn} />
        </div>
        <div class="title">
          <span class="status-dot"></span>
          <I18nText zh={sidebarTitleZh} en={sidebarTitleEn} />
        </div>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section nav-section-compact">
          <div class="nav-section-label">
            <I18nText zh="语言" en="Language" />
          </div>
          <div
            class="language-switch language-switch-sidebar"
            role="group"
            aria-label="语言切换"
            data-i18n-aria-label-zh="语言切换"
            data-i18n-aria-label-en="Language switch"
          >
            <button type="button" class="language-btn" data-set-language="zh">中</button>
            <button type="button" class="language-btn" data-set-language="en">EN</button>
          </div>
        </div>

        <div class="nav-section">
          <div class="nav-section-label">
            <I18nText zh="导航" en="Navigation" />
          </div>
          <a href="/" class:list={['nav-link', { active: activePage === 'home' }]}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <I18nText zh={pageSettings.home.navLabel} en={pageSettings.home.navLabelEn ?? pageSettings.home.navLabel} />
          </a>
          <a href="/portfolio" class:list={['nav-link', { active: activePage === 'portfolio' }]}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <I18nText zh={pageSettings.portfolio.navLabel} en={pageSettings.portfolio.navLabelEn ?? pageSettings.portfolio.navLabel} />
          </a>
          <a href="/thoughts" class:list={['nav-link', { active: activePage === 'thoughts' }]}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <I18nText zh={pageSettings.thoughts.navLabel} en={pageSettings.thoughts.navLabelEn ?? pageSettings.thoughts.navLabel} />
          </a>
          <a href="/life" class:list={['nav-link', { active: activePage === 'life' }]}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><circle cx="9" cy="10" r="1.5"/><path d="m13 15 2.5-3 3.5 4"/></svg>
            <I18nText zh={pageSettings.life.navLabel} en={pageSettings.life.navLabelEn ?? pageSettings.life.navLabel} />
          </a>
          <a href="/channel" class:list={['nav-link', { active: activePage === 'channel' }]}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            <I18nText zh={pageSettings.channel.navLabel} en={pageSettings.channel.navLabelEn ?? pageSettings.channel.navLabel} />
          </a>
        </div>

        <div class="nav-section">
          <div class="nav-section-label">
            <I18nText zh="联系" en="Contact" />
          </div>
          {contactEmail ? (
            <a href={contactEmailHref} class="nav-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <I18nText zh="发送邮件" en="Send Email" />
            </a>
          ) : (
            <span class="nav-link nav-link-disabled">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <I18nText zh="发送邮件" en="Send Email" />
            </span>
          )}
        </div>
      </nav>

      <div class="sidebar-footer">
        <div class="sidebar-footer-label">
          <I18nText zh="在这里找到我" en="Find Me Here" />
        </div>
        <div class="social-links">
          {findMeLinks.map((link) => {
            const labels = socialPlatformLabels[link.platform];
            const labelZh = link.label ?? labels.zh;
            const labelEn = link.label ?? labels.en;
            const Tag = link.url ? 'a' : 'span';

            return (
              <Tag
                href={link.url}
                class:list={['social-link', { 'social-link-disabled': !link.url }]}
                aria-label={labelEn}
                data-i18n-aria-label-zh={labelZh}
                data-i18n-aria-label-en={labelEn}
                target={link.url ? '_blank' : undefined}
                rel={link.url ? 'noopener' : undefined}
              >
                {link.platform === 'github' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                  </svg>
                )}
                {link.platform === 'linkedin' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                )}
                {link.platform === 'huggingface' && (
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8" />
                    <circle cx="9" cy="10" r="1.2" fill="currentColor" />
                    <circle cx="15" cy="10" r="1.2" fill="currentColor" />
                    <path d="M8 14c1 1.4 2.3 2 4 2s3-.6 4-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                  </svg>
                )}
                {link.platform === 'website' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M2 12h20" />
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  </svg>
                )}
              </Tag>
            );
          })}
        </div>
      </div>
    </aside>

    <main class="main-content" role="main">
      <slot />
    </main>
  </div>

  <script src="/js/main.js" is:inline></script>
</body>
</html>
